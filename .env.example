# ==============================================================================
# Environment Configuration Template for Session Summarizer
# Copy this file to '.env' and fill in your secrets. Do not check .env into Git.
# ==============================================================================

# Application Environment (development, production, testing)
APP_ENV=development

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Adapter Provider Selection
# ------------------------------------------------------------------------------
TRANSCRIBER_PROVIDER=faster_whisper
SUMMARIZER_PROVIDER=gemini
STORAGE_PROVIDER=json

# ------------------------------------------------------------------------------
# Faster-Whisper Transcriber Configuration
# ------------------------------------------------------------------------------
WHISPER_MODEL_SIZE=base
# Use 'cpu' or 'cuda' (GPU)
WHISPER_DEVICE=cpu

# ------------------------------------------------------------------------------
# Google Gemini Summarizer Configuration
# ------------------------------------------------------------------------------
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-1.5-flash

# ------------------------------------------------------------------------------
# JSON Storage Configuration
# ------------------------------------------------------------------------------
STORAGE_JSON_DIR=./data
